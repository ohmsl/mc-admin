# Backend: PocketBase + RCON
MC_ADMIN_PORT=8090
MC_RCON_HOST=minecraft
MC_RCON_PORT=25575
MC_RCON_PASSWORD=change-me
MC_RCON_TIMEOUT_SECONDS=5
MC_RCON_RETRY_COUNT=1
MC_ALLOW_RAW_COMMAND=false
MC_AUDIT_COLLECTION=mc_audit_logs
MC_ROLE_FIELD=role

# Frontend (Vite dev server only)
# Set this when running web dev server on a different port than PocketBase.
VITE_POCKETBASE_URL=http://127.0.0.1:8090
